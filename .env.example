# StoreLink API credentials — per-store keys, rotated weekly by Korral IT
#
# ── Rotation schedule ────────────────────────────────────────────────────────
#   Keys rotate every Monday at 10:00 UTC.
#   IT must deploy the next key block at least one hour before rotation.
#
#   The server uses a 10-minute overlap window:
#     NEXT_VALID_FROM = EXPIRES − 10 min
#
#   During this window the server switches new requests to the NEXT key while
#   any request already in flight with the CURRENT key completes normally.
#
# ── IT checklist for rotation ────────────────────────────────────────────────
#   1. Generate new keys for all active stores
#   2. Populate the _NEXT and _NEXT_VALID_FROM lines below (uncomment them)
#   3. Deploy .env to the server — at least 1 hour before EXPIRES
#   4. After EXPIRES passes, promote NEXT → CURRENT, update EXPIRES, clear NEXT lines
#
# ── Key format ───────────────────────────────────────────────────────────────
#   sk_live_<STOREID_NO_DASH>_<32-char-random>
#   Example for STR-047:  sk_live_STR047_a1b2c3d4e5f6...
#   The store ID fragment (STR047) is validated server-side — using a key from
#   the wrong store will return 403 KEY_STORE_MISMATCH and log a security alert.
#
# ── Env var naming ───────────────────────────────────────────────────────────
#   Store IDs use underscores in var names: STR-047 → STR_047
#
# ─────────────────────────────────────────────────────────────────────────────

# Store STR-047
STORELINK_KEY_STR_047_CURRENT=sk_live_STR047_<replace-with-actual-key>
STORELINK_KEY_STR_047_EXPIRES=<ISO-8601 e.g. 2027-06-07T10:00:00Z>
# Uncomment and populate the week before rotation:
# STORELINK_KEY_STR_047_NEXT=sk_live_STR047_<replace-with-next-key>
# STORELINK_KEY_STR_047_NEXT_VALID_FROM=<EXPIRES minus 10 min e.g. 2027-06-07T09:50:00Z>

# Store STR-102
STORELINK_KEY_STR_102_CURRENT=sk_live_STR102_<replace-with-actual-key>
STORELINK_KEY_STR_102_EXPIRES=<ISO-8601 e.g. 2027-06-07T10:00:00Z>
# Uncomment and populate the week before rotation:
# STORELINK_KEY_STR_102_NEXT=sk_live_STR102_<replace-with-next-key>
# STORELINK_KEY_STR_102_NEXT_VALID_FROM=<EXPIRES minus 10 min e.g. 2027-06-07T09:50:00Z>

# Add a block per store following the same pattern:
# STORELINK_KEY_STR_<NNN>_CURRENT=sk_live_STR<NNN>_<key>
# STORELINK_KEY_STR_<NNN>_EXPIRES=<ISO-8601>
